# ─────────────────────────────────
# AI Route Planner — 环境变量配置
# ─────────────────────────────────

# DeepSeek LLM API 配置
# 从 https://platform.deepseek.com 创建 API Key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1

# 美团开放平台 Token (开发者Token)
# 从 https://open.meituan.com 获取
MEITUAN_API_TOKEN=your-meituan-api-token

# 如需切换为 OpenAI，修改 LLM_BASE_URL 即可：
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4
