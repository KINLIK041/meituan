# ─────────────────────────────────────────
# AI Route Planner — 生产环境变量
# 复制此文件为 .env 并填入真实值
#   cp .env.production .env
# ─────────────────────────────────────────

# DeepSeek LLM (必填)
# 从 https://platform.deepseek.com 获取
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1

# 高德地图 API Key (必填，地理编码用)
# 从 https://console.amap.com 获取
GAODE_API_KEY=your-gaode-api-key

# 美团开放平台 Token (选填，mock profile 下不使用)
MEITUAN_API_TOKEN=your-meituan-api-token

# Spring profile: mock=本地数据, dianping=美团实时数据
SPRING_PROFILES_ACTIVE=mock

# PostgreSQL (不改也可以，只在内网使用)
POSTGRES_DB=liquidroute
POSTGRES_USER=liquidroute
POSTGRES_PASSWORD=请修改为随机密码
